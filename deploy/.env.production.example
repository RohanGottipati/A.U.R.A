# Template for the production .env.local on the Vultr VPS.
#
# Copy this to /home/deploy/aura/.env.local on the server and fill in the
# real values from your local .env.local. The ONLY value that should differ
# from local is APP_BASE_URL - it must point at the externally reachable URL.
#
# scp deploy/.env.production.example deploy@<VPS_IP>:/home/deploy/aura/.env.local

# Gemini vision/language model
GEMINI_API_KEY=

# Vultr Managed Postgres - same DATABASE_URL as local
DATABASE_URL=

# Externally reachable base URL for the app (used for share links).
# For HTTP-only IP deploy: APP_BASE_URL=http://<VPS_IP>
# For a custom domain later: APP_BASE_URL=https://your.domain
APP_BASE_URL=http://REPLACE_WITH_VPS_IP

# Vultr Object Storage (S3-compatible) - same bucket as local
VULTR_STORAGE_ENDPOINT=https://ewr1.vultrobjects.com
VULTR_STORAGE_BUCKET=floorplan-ai-storage
VULTR_STORAGE_ACCESS_KEY=
VULTR_STORAGE_SECRET_KEY=

# Internal service-to-service secret
SERVICE_SECRET=

# Backboard agent orchestration
BACKBOARD_API_KEY=
# Optional - cached assistant ids returned by `npm run setup-backboard`
# BACKBOARD_AGENT1_ASSISTANT_ID=
# BACKBOARD_AGENT2_ASSISTANT_ID=
# BACKBOARD_AGENT3_ASSISTANT_ID=

# NOTE: Do NOT set NODE_ENV here. PM2's ecosystem.config.cjs sets it at
# runtime; setting it in .env.local makes `npm ci` skip devDependencies
# (tailwind, postcss, typescript) and the build then fails.
