# Shared A.U.R.A environment reference.
# This file is for teammate setup only. The apps still load frontend/.env.local and backend/.env.local.

# NextAuth: session signing and callback URLs
NEXTAUTH_SECRET="replace-with-a-generated-secret"
NEXTAUTH_URL="http://localhost:3001"

# GitHub OAuth: NextAuth GitHub provider and repo access
GITHUB_CLIENT_ID="replace-with-your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="replace-with-your-github-oauth-client-secret"
GITHUB_PAT="replace-with-your-github-personal-access-token"

# OpenAI: model access for AURA agents
OPENAI_API_KEY="replace-with-your-openai-api-key"

# Google Gemini: model access for Gemini/Gemma requests
GOOGLE_GEMINI_API_KEY="replace-with-your-google-gemini-api-key"

# Google Cloud Vision: API access and optional service account path
GOOGLE_CLOUD_VISION_API_KEY="replace-with-your-google-cloud-vision-api-key"
GOOGLE_APPLICATION_CREDENTIALS="./gcp-service-account.json"

# Vultr Managed PostgreSQL: primary application database
DATABASE_URL="postgresql://username:password@hostname:5432/aura?sslmode=require"

# Vultr Object Storage: screenshot and asset storage
VULTR_STORAGE_ENDPOINT="https://ewr1.vultrobjects.com"
VULTR_STORAGE_ACCESS_KEY="replace-with-your-vultr-storage-access-key"
VULTR_STORAGE_SECRET_KEY="replace-with-your-vultr-storage-secret-key"
VULTR_STORAGE_BUCKET="replace-with-your-vultr-storage-bucket"

# Playwright Service: remote browser automation service
PLAYWRIGHT_SERVICE_URL="http://localhost:3002"
PLAYWRIGHT_SERVICE_SECRET="replace-with-a-shared-service-secret"

# Backboard: API access for org-scoped automation
BACKBOARD_API_KEY="replace-with-your-backboard-api-key"
BACKBOARD_ORG_ID="replace-with-your-backboard-org-id"

# Vercel: preview deployment access
VERCEL_TOKEN="replace-with-your-vercel-token"
VERCEL_TEAM_ID="replace-with-your-vercel-team-id"
