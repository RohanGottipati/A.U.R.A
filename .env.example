# FloorPlan AI -- Environment Variables
# Copy this file to .env.local and fill in real values.

# ==========================================
# GEMINI API -- required for the floor plan analysis pipeline
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override the Gemini model used for direct calls (vision). Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# ==========================================
# VULTR POSTGRESQL -- required for job and scene persistence
# ==========================================
DATABASE_URL=postgresql://floorplan_app:PASSWORD@HOST:PORT/floorplan_ai?sslmode=require

# ==========================================
# APP URL -- required for share links stored in the database
# ==========================================
APP_BASE_URL=http://localhost:3000

# ==========================================
# VULTR OBJECT STORAGE -- required for floor plan uploads and scene JSON storage
# ==========================================
VULTR_STORAGE_ENDPOINT=https://ewr1.vultrobjects.com
VULTR_STORAGE_BUCKET=floorplan-ai-storage
VULTR_STORAGE_ACCESS_KEY=your_vultr_object_storage_access_key
VULTR_STORAGE_SECRET_KEY=your_vultr_object_storage_secret_key

# ==========================================
# BACKBOARD -- required for agent orchestration through Backboard API
# ==========================================
BACKBOARD_API_KEY=your_backboard_api_key
# Optional: model used for Backboard agent calls (defaults to google / gemini-2.0-flash)
BACKBOARD_LLM_PROVIDER=google
BACKBOARD_MODEL_NAME=gemini-2.5-flash
# Optional: assistant IDs returned by `npm run setup-backboard`. If unset, the app
# creates new assistants on first use and caches them in-memory for the process lifetime.
# BACKBOARD_AGENT1_ASSISTANT_ID=
# BACKBOARD_AGENT2_ASSISTANT_ID=
# BACKBOARD_AGENT3_ASSISTANT_ID=
